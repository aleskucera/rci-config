#!/bin/bash
set -euo pipefail

PORT=9999
user=$(whoami)
HOME_DIR="/home/$user"
STORAGE_DIR="/mnt/personal/$user"
SETUP_DIR="$HOME_DIR/rci-config"
SRC_DIR="$SETUP_DIR/src"
LAST_FILE="$HOME_DIR/.run-jupyter-last"

# Per-invocation temp files so concurrent run-jupyter calls don't collide
NODE_FILE=$(mktemp -t rci-jupyter-node.XXXXXX)
LOG_FILE=$(mktemp -t rci-jupyter-log.XXXXXX)
trap 'rm -f "$NODE_FILE" "$LOG_FILE"' EXIT

echo ""
echo "==== Running Remote Jupyter Kernel ===="
echo ""

# Offer to reuse last settings
reuse_last=false
if [ -f "$LAST_FILE" ]; then
    echo "Last run:"
    sed 's/^/  /' "$LAST_FILE"
    echo ""
    read -r -p "Reuse these settings? [Y/n] " ans
    if [[ -z "$ans" || "$ans" =~ ^[yY]$ ]]; then
        # shellcheck disable=SC1090
        source "$LAST_FILE"
        reuse_last=true
    fi
    echo ""
fi

if [ "$reuse_last" = false ]; then
    projects=("$HOME_DIR/projects"/*)
    echo "Choose the project for which you wish to run the remote Jupyter kernel:"
    echo ""
    for ((i = 1; i <= ${#projects[@]}; i++)); do
        echo "[$i] $(basename "${projects[$((i-1))]}")"
    done
    echo ""
    read -r -p "Enter the number of the project: " project_number
    echo ""

    if ! [[ "$project_number" =~ ^[0-9]+$ ]] || [ "$project_number" -lt 1 ] || [ "$project_number" -gt "${#projects[@]}" ]; then
        echo "ERROR: Invalid input: Please enter a valid number."
        exit 1
    fi
    project_dir="${projects[$((project_number - 1))]}"

    SCRIPT_DIR="$(realpath "$(dirname "${BASH_SOURCE[0]}")")"
    # shellcheck source=_select-partition
    source "$SCRIPT_DIR/_select-partition"

    gpus=0
    if [ "$choice_is_gpu" -eq 1 ]; then
        echo ""
        read -r -p "Number of GPUs [default=1]: " gpus
        gpus="${gpus:-1}"
        if ! [[ "$gpus" =~ ^[0-9]+$ ]] || [ "$gpus" -lt 1 ]; then
            echo "Invalid number of GPUs. Aborting..."
            exit 1
        fi
    fi

    echo ""
    read -r -p "Memory [default=8G]: " memory
    memory="${memory:-8G}"
    if ! [[ "$memory" =~ ^[0-9]+[KMGT]?$ ]]; then
        echo "Invalid memory value. Aborting..."
        exit 1
    fi

    echo ""
    read -r -p "Number of CPUs [default=4]: " cpus
    cpus="${cpus:-4}"
    if ! [[ "$cpus" =~ ^[0-9]+$ ]] || [ "$cpus" -lt 1 ]; then
        echo "Invalid number of CPUs. Aborting..."
        exit 1
    fi

    cat > "$LAST_FILE" <<EOF
project_dir="$project_dir"
partition="$partition"
gpus="$gpus"
memory="$memory"
cpus="$cpus"
EOF
fi

# Derived values
project_name=$(basename "$project_dir")
log_dir="${project_dir}/rci-logs"

# Re-detect environment on every run (in case .env/.venv was added since last time)
env_file=null
singularity_file=null
if [ -f "${project_dir}/.env" ]; then
    echo "Detected .env file, using it."
    env_file="${project_dir}/.env"
elif [ -f "${project_dir}/.venv/bin/activate" ]; then
    echo "Detected .venv, using it."
    env_file="${project_dir}/.venv/bin/activate"
else
    echo "No .env or .venv found. Choose an environment:"
    echo "[1] Base environment (modules)"
    echo "[2] Singularity image"
    echo ""
    read -r -p "Enter the number of the option: " option
    echo ""

    if [ "$option" -eq 1 ]; then
        env_file="${SETUP_DIR}/envs/base.sh"
    elif [ "$option" -eq 2 ]; then
        singularity_file="${STORAGE_DIR}/singularity/${project_name}.sif"
        if [ ! -f "$singularity_file" ]; then
            echo "WARNING: The file $singularity_file does not exist."
            read -r -p "Do you want to load base singularity image? (y/n) " response
            echo ""
            if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
                singularity_file="${STORAGE_DIR}/singularity/base.sif"
            else
                echo "Aborting..."
                exit 1
            fi
        fi
    else
        echo "ERROR: Invalid option."
        exit 1
    fi
fi

# Fill the jinja2 template
python "$SRC_DIR/create_job_file.py" \
    --port "$PORT" \
    --project_name "$project_name" \
    --partition "$partition" \
    --gpus "$gpus" \
    --memory "$memory" \
    --number_of_cpus "$cpus" \
    --env_file "$env_file" \
    --singularity_file "$singularity_file" \
    --log_dir "$log_dir" \
    --project_dir "$project_dir" \
    --log_file "$LOG_FILE" \
    --node_file "$NODE_FILE"

# Submit the job, then remove the generated script so jobs/ doesn't accumulate
# (sbatch reads the script into SLURM at submit time, so deleting is safe)
job_script="${SETUP_DIR}/jobs/${project_name}.sh"
echo "Submitting the job..."
sbatch "$job_script"
rm -f "$job_script"

# Wait until the job-side script populates both temp files
echo "Waiting for the job to start..."
while [[ ! -s $NODE_FILE ]] || [[ ! -s $LOG_FILE ]]; do
    sleep 1
done
node=$(cat "$NODE_FILE")
log_path=$(cat "$LOG_FILE")

echo ""
echo "On your local machine, run:"
echo "    rci-tunnel $node $PORT"
echo "or manually:"
echo "    ssh -N -L $PORT:$node:$PORT $user@login.rci.cvut.cz"

echo ""
echo "Then the Jupyter notebook will be available at:"
echo "    http://localhost:$PORT"

echo ""
echo "Logs:"
echo "    $log_path"
echo "(or run \`job-logs\` on RCI)"

echo ""
echo "==== Remote Jupyter Kernel Running ===="
echo ""
