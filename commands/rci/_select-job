#!/bin/bash
# Shared helper: lists the user's jobs and prompts for selection.
# Sets $job_id on success; exits with code 1 on failure.
# Usage: source _select-job "<prompt text>"

_prompt="${1:-Enter the number of the job}"

user_jobs=$(squeue -u "$USER")

if [ "$(echo "$user_jobs" | wc -l)" -eq 1 ]; then
    echo "No jobs found for user $USER"
    exit 1
fi

echo ""
echo "Jobs for user $USER:"
echo "$user_jobs" | awk 'NR == 1 {print $0}'
echo "$user_jobs" | awk 'NR > 1 {print "["NR-1"]", $0}'
echo ""

read -r -p "$_prompt: " job_number

if ! [[ "$job_number" =~ ^[0-9]+$ ]]; then
    echo "Invalid input: Please enter a number."
    exit 1
fi

job_id=$(echo "$user_jobs" | awk 'NR > 1' | awk -v n="$job_number" 'NR == n {print $1}')

if [ -z "$job_id" ]; then
    echo "Invalid job number."
    exit 1
fi
